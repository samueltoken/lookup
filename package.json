{
  "name": "lookup",
  "version": "1.2.8",
  "description": "Free document viewer without login",
  "main": "main.js",
  "scripts": {
    "build:icon": "node scripts/generate-duck-icon.mjs",
    "start": "npm run build:icon && electron .",
    "dist": "npm run build:icon && node scripts/check-utf8-messages.mjs && electron-builder --win nsis --publish never && node scripts/generate-latest-yml.mjs",
    "pack": "npm run build:icon && electron-builder --dir"
  },
  "keywords": [
    "pdf",
    "viewer",
    "electron"
  ],
  "author": "lookup",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samueltoken/lookup.git"
  },
  "type": "commonjs",
  "dependencies": {
    "@ohah/hwpjs": "^0.1.0-rc.10",
    "@rhwp/core": "^0.7.2",
    "electron-updater": "^6.8.3",
    "hwpx-js": "^0.1.2",
    "officeparser": "^6.0.7",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.6.0",
    "pdfjs-dist": "^5.6.205",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "pngjs": "^7.0.0",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.lookup.pdfviewer",
    "productName": "lookup",
    "artifactName": "lookup-Setup-${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "update-config.json",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "executableName": "lookup",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "fileAssociations": [
        {
          "ext": "pdf",
          "name": "lookup PDF",
          "description": "Open PDF with lookup",
          "icon": "build/icon.ico"
        },
        {
          "ext": "hwp",
          "name": "lookup HWP",
          "description": "Open HWP with lookup",
          "icon": "build/icon.ico"
        },
        {
          "ext": "hwpx",
          "name": "lookup HWPX",
          "description": "Open HWPX with lookup",
          "icon": "build/icon.ico"
        },
        {
          "ext": "doc",
          "name": "lookup DOC",
          "description": "Open DOC with lookup",
          "icon": "build/icon.ico"
        },
        {
          "ext": "docx",
          "name": "lookup DOCX",
          "description": "Open DOCX with lookup",
          "icon": "build/icon.ico"
        },
        {
          "ext": "xls",
          "name": "lookup XLS",
          "description": "Open XLS with lookup",
          "icon": "build/icon.ico"
        },
        {
          "ext": "xlsx",
          "name": "lookup XLSX",
          "description": "Open XLSX with lookup",
          "icon": "build/icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "warningsAsErrors": false,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "lookup",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    },
    "afterPack": "scripts/after-pack.mjs"
  }
}
